<?xml version="1.0" encoding="UTF-8"?>
<state id="11009" name="NOAC_QA_Helper_State" concept-type="state">
	<categories/>
	<standard-terms/>
	<synonyms/>
	<temporal-semantic downward-hereditary="true" forward="true" backward="true" solid="true" concatenable="true" gestalt="true"/>
	<clippers/>
	<derived-from>
		<derived-from-id>504</derived-from-id> <!-- Raw NOAC State -->
	</derived-from>
	<abstraction-at-contexts/>
	<mapping-function rank-selection-criteria="min">
		<mapping-functions-to-values>
			<mapping-function-2-value order="0" value="True">
				<evaluation-tree data-type="comparison-function">
					<comparison-function comparison-operator="equal">
						<left data-type="concept-id-allowed-values"><concept-id-allowed-values id="504"/></left>
						<right data-type="string"><string>True</string></right>
					</comparison-function>
				</evaluation-tree>
			</mapping-function-2-value>
		</mapping-functions-to-values>
	</mapping-function>
	<ordinal-allowed-values output-type="ordinal">
		<persistence>
			<!-- EXTENDED PERSISTENCE: This is the key. 
			     It extends the single purchase event 1 year back and 1 year forward.
			     This ensures that if a patient purchased the drug roughly within the QA window, 
			     this state will overlap the ENTIRE window. -->
			<global-persistence granularity="second"><interpolation-table><rows/></interpolation-table></global-persistence>
			<local-persistence>
				<good-before value="1" granularity="year"/>
				<good-after value="1" granularity="year"/>
			</local-persistence>
		</persistence>
		<values>
			<ordinal-allowed-value order="0" value="True"/>
		</values>
	</ordinal-allowed-values>
</state>
